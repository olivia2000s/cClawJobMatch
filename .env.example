# OPTIONAL — pre-fill the keys instead of typing them into the UI each run.
# Anything VITE_-prefixed is inlined into the client bundle, so it is VISIBLE to
# anyone who opens the page. Fine for a local hackathon demo with throwaway keys;
# do NOT ship a real Anthropic key this way in production.
#
# Copy this file to `.env` and fill in what you want. The UI also accepts these
# keys directly (stored in localStorage), so .env is purely a convenience.

# Anthropic API key — used in-browser via dangerouslyAllowBrowser to score jobs.
VITE_ANTHROPIC_API_KEY=

# McClaw API key (X-API-Key). Get it from your McClaw account. Leave blank to
# run on the built-in sample gigs.
VITE_MCCLAW_API_KEY=

# Override the scoring model. Defaults to claude-haiku-4-5 (fast + cheap).
# Use claude-sonnet-4-6 for more nuanced matching.
VITE_SCORING_MODEL=claude-haiku-4-5

# OPTIONAL — wallet $MCLAW balance check before the on-chain hand-off. Set this
# to the $MCLAW ERC-20 contract address to show the user's balance and warn if
# it won't cover a task's stake. Leave blank to connect address-only (no balance).
VITE_MCLAW_TOKEN_ADDRESS=

# OPTIONAL — override the McClaw site URL the apply steps link out to.
# Defaults to https://mcclaw.io.
VITE_MCCLAW_URL=
